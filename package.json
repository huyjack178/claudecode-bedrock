{
  "name": "@huyjack178/claude-bedrock-setup",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "1.0.32",
  "description": "One-command CLI to configure Claude Code with Amazon Bedrock",
  "bin": {
    "claude-bedrock-setup": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "iam-policy.json"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "bedrock",
    "aws",
    "anthropic",
    "claude-code"
  ],
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/setup.js --bundle --platform=node --format=cjs --outfile=dist/setup.cjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@yao-pkg/pkg": "^5.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/huyjack178/claudecode-bedrock.git"
  }
}
